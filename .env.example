# Database  (TimescaleDB — docker compose up)
DATABASE_URL=postgresql+psycopg2://tennis:tennis@localhost:5432/tennis_bot

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text

# Discovery & Status
DISCOVERY_INTERVAL_SECONDS=43200
STATUS_CHECK_INTERVAL_SECONDS=300
DISCOVERY_ENABLED=true

# Live Collection
LIVE_SCORE_INTERVAL_SECONDS=10
LIVE_ODDS_INTERVAL_SECONDS=2
LIVE_PREFETCH_MINUTES=5
